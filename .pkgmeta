package-as: DragonToast
enable-toc-creation: yes
manual-changelog: .release/CHANGELOG.md

move-folders:
    DragonToast/DragonToast: DragonToast
    DragonToast/DragonToast_Options: DragonToast_Options

externals:
  DragonToast/Libs/Ace3: https://repos.wowace.com/wow/ace3/trunk
  DragonToast/Libs/LibDataBroker-1.1: https://github.com/tekkub/libdatabroker-1-1
  DragonToast/Libs/LibDBIcon-1.0: https://repos.wowace.com/wow/libdbicon-1-0/trunk/LibDBIcon-1.0
  DragonToast/Libs/LibSharedMedia-3.0: https://repos.wowace.com/wow/libsharedmedia-3-0/trunk/LibSharedMedia-3.0
  DragonToast/Libs/LibAnimate: https://github.com/Xerrion/LibAnimate

ignore:
  - ".git*"
  - .luacheckrc
  - .release
  - scripts
  - "*.md"
  - "*.png"
  - release-please-config.json
  - .release-please-manifest.json
  - spec/
  - scripts/
  - "Assets/*logo*"
